# Common plotting parameters
min_bubble_size = 50
max_bubble_size = 2000

figure, axis = plt.subplots(1, 3, figsize=(12, 6))
all_data_melted = pd.concat([pd.DataFrame(config['data']).melt(id_vars='Genus', var_name='Time', value_name='Value') for config in plot_configs])
global_min_val = all_data_melted['Value'].min()
global_max_val = all_data_melted['Value'].max()

# Loop through each configuration to generate a plot
for i, config in enumerate(plot_configs):
    
    # Convert the data into a pandas DataFrame
    df = pd.DataFrame(config['data'])

    # Reshape the dataframe to have a suitable format for plotting
    df_melted = df.melt(id_vars='Genus', var_name='Time', value_name='Value')

    # Normalize the values to scale bubble sizes
    df_melted['BubbleSize'] = (df_melted['Value'] - df_melted['Value'].min()) / \
                              (df_melted['Value'].max() - df_melted['Value'].min()) * \
                              (max_bubble_size - min_bubble_size) + min_bubble_size

    # # Create the plot figure
    # plt.figure(figsize=config['figsize'])
    # axis[i].figure.set_figwidth(config['figsize'][0])
    # axis[i].figure.set_figheight(config['figsize'][1])
    
    # Plot using seaborn
    scatter = sns.scatterplot(
        data=df_melted,
        x='Time',
        y='Genus',
        size='BubbleSize',
        sizes=(min_bubble_size, max_bubble_size),
        hue='Value',
        palette='coolwarm',
        legend=False, # Disable the default legend
        ax=axis[i],
    )
    
    # Rotate the x-axis labels to prevent them from overlapping
    # axis[i].set_xticklabels(rotation=45, ha='right')
    
    # Set x and y limits based on the configuration
    axis[i].set_xlim(config['xlim'])
    axis[i].set_ylim(9.5, -1)
    
    # Add labels and titles
    axis[i].set_title(config['title'], fontsize=16)
    if (i == 1):
        axis[i].set_xlabel('Time (Days)', fontsize=16, weight="bold")
    else:
        axis[i].set_xlabel('')
    if (i == 0):
        axis[i].set_ylabel('Genus', fontsize=16, weight="bold")
    else:
        axis[i].set_ylabel('')

# 2. Create the color bar
# First, create a new axes for the color bar
cbar_ax = figure.add_axes([0.92, 0.15, 0.02, 0.7])  # [left, bottom, width, height]

# Create a mappable object with the same colormap and normalization
cmap = mpl.cm.coolwarm
norm = mpl.colors.Normalize(vmin=global_min_val, vmax=60)
mappable = mpl.cm.ScalarMappable(norm=norm, cmap=cmap)

# Add the color bar to the new axes
cbar = figure.colorbar(mappable, cax=cbar_ax)
cbar.set_label('Relative Abundance (%)', rotation=270, labelpad=15, fontsize=16)

# Adjust layout to prevent labels from being cut off
plt.tight_layout(rect=[0, 0, 0.9, 1])

# Save the figure with the specified filename and resolution
plt.savefig("combined_16S_plot_5.png", format="png", dpi=1000, bbox_inches='tight')

